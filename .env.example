# LLM Provider: "openai" (default) or "openrouter"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# OpenRouter (only needed if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...

# Model override (optional)
# For OpenAI: gpt-4o, gpt-4o-mini, etc.
# For OpenRouter: qwen/qwen-2.5-72b-instruct, anthropic/claude-3.5-sonnet, etc.
OPENAI_MODEL=gpt-4o-mini

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
